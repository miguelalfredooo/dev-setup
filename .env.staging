# Staging Environment Template
# Copy to .env.staging in your project root and customize
# Staging should mirror production setup but with staging service endpoints

# Supabase (staging instance)
NEXT_PUBLIC_SUPABASE_URL=https://staging-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key
SUPABASE_URL=https://staging-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_staging_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_supabase_service_role_key

# APIs (staging)
ANTHROPIC_API_KEY=your_anthropic_staging_key
OPENAI_API_KEY=your_openai_staging_key
PEXELS_API_KEY=your_pexels_staging_key

# Carrier & Services (staging)
CARRIER_API_URL=https://staging-carrier-api.example.com
CREW_API_URL=https://staging-crew-api.example.com

# Browserbase (staging)
BROWSERBASE_API_KEY=your_browserbase_staging_key
BROWSERBASE_PROJECT_ID=your_browserbase_staging_project_id

# Ollama (staging - can be local or remote)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5

# App Config
NEXT_PUBLIC_AUTH_REQUIRED=true
CLAUDE_MODEL=claude-3-5-sonnet-20241022
NODE_ENV=staging

# Design Tools
DESIGN_TOOLS_PASSWORD=your_staging_design_tools_password

# Other
MODEL_API_KEY=your_model_staging_key
